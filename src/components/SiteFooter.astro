---
import { site } from "../content/site";

type Props = {
  variant?: "default" | "about";
};

const { variant = "default" } = Astro.props;
---

<footer class:list={["site-footer", variant === "about" && "site-footer--about"]}>
  <nav class="site-container site-footer__grid" aria-label="Footer navigation">
    <a class="site-footer__brand" href="/" aria-label="eCongruity home">
      <img
        src="/images/brand/econgruity-logo-footer-pale-leaf.png"
        alt=""
        width="1657"
        height="390"
        loading="lazy"
        decoding="async"
      />
    </a>
    <p>{site.positioning}</p>
    <address>45 Business Park Road, Unit #C — Livingston, MT 59047</address>
    <p>© 2025 eCongruity. All Rights Reserved.</p>
  </nav>
</footer>
