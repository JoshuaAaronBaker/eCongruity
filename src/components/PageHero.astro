---
type Props = {
  eyebrow: string;
  title: string;
  summary: string;
};

const { eyebrow, title, summary } = Astro.props;
---

<section class="page-hero">
  <div class="site-container page-hero__inner">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{summary}</p>
    <slot />
  </div>
</section>
