---
const fields = [
  {
    id: "contact-first-name",
    label: "First Name",
    name: "first-name",
    type: "text",
    autocomplete: "given-name",
    group: "half",
  },
  {
    id: "contact-last-name",
    label: "Last Name",
    name: "last-name",
    type: "text",
    autocomplete: "family-name",
    group: "half",
  },
  {
    id: "contact-email",
    label: "Email Address",
    name: "email",
    type: "email",
    autocomplete: "email",
  },
  {
    id: "contact-organization",
    label: "Company / Organization",
    name: "organization",
    type: "text",
    autocomplete: "organization",
  },
] satisfies {
  id: string;
  label: string;
  name: string;
  type: "text" | "email";
  autocomplete: string;
  group?: "half";
}[];
---

<form
  class="contact-form"
  name="start-the-conversation"
  method="post"
  data-netlify="true"
  netlify-honeypot="company-website"
>
  <input type="hidden" name="form-name" value="start-the-conversation" />
  <p class="contact-form__honeypot">
    <label>
      Company website
      <input name="company-website" tabindex="-1" autocomplete="off" />
    </label>
  </p>

  {
    fields.map((field) => (
      <div class:list={["contact-form__field", field.group === "half" && "contact-form__field--half"]}>
        <label for={field.id}>{field.label}</label>
        <input
          id={field.id}
          type={field.type}
          name={field.name}
          autocomplete={field.autocomplete}
          required
        />
      </div>
    ))
  }

  <div class="contact-form__field">
    <label for="contact-problem">What problem are you facing?</label>
    <textarea
      id="contact-problem"
      name="problem"
      required
      rows="5"
    ></textarea>
  </div>

  <button class="button-link button-link--secondary contact-form__continue" type="submit">
    Continue <span aria-hidden="true">→</span>
  </button>
</form>
