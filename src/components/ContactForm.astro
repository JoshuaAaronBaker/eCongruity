---
const fields = [
  {
    id: "contact-first-name",
    label: "First Name",
    name: "first-name",
    type: "text",
    autocomplete: "given-name",
    group: "half",
  },
  {
    id: "contact-last-name",
    label: "Last Name",
    name: "last-name",
    type: "text",
    autocomplete: "family-name",
    group: "half",
  },
  {
    id: "contact-email",
    label: "Email Address",
    name: "email",
    type: "email",
    autocomplete: "email",
  },
  {
    id: "contact-organization",
    label: "Company / Organization",
    name: "organization",
    type: "text",
    autocomplete: "organization",
  },
] satisfies {
  id: string;
  label: string;
  name: string;
  type: "text" | "email";
  autocomplete: string;
  group?: "half";
}[];
---

<form
  class="contact-form"
  data-contact-form
  name="start-the-conversation"
  method="post"
  action="/contact/"
  data-netlify="true"
  netlify-honeypot="company-website"
>
  <input type="hidden" name="form-name" value="start-the-conversation" />
  <p class="contact-form__honeypot">
    <label>
      Company website
      <input name="company-website" tabindex="-1" autocomplete="off" />
    </label>
  </p>

  {
    fields.map((field) => (
      <div class:list={["contact-form__field", field.group === "half" && "contact-form__field--half"]}>
        <label for={field.id}>{field.label}</label>
        <input
          id={field.id}
          type={field.type}
          name={field.name}
          autocomplete={field.autocomplete}
          required
        />
      </div>
    ))
  }

  <div class="contact-form__field contact-form__field--problem">
    <label for="contact-problem">What problem are you facing?</label>
    <textarea
      id="contact-problem"
      name="problem"
      required
      rows="5"
    ></textarea>
  </div>

  <button class="button-link button-link--secondary contact-form__continue" type="submit">
    <span data-submit-label>Continue</span> <span aria-hidden="true">→</span>
  </button>
</form>

<div class="site-toast" data-site-toast role="status" aria-live="polite" aria-atomic="true" hidden>
  <span class="site-toast__mark" aria-hidden="true"></span>
  <span data-site-toast-message></span>
</div>

<script>
  const contactForm = document.querySelector<HTMLFormElement>("[data-contact-form]");
  const toast = document.querySelector<HTMLElement>("[data-site-toast]");
  const toastMessage = toast?.querySelector<HTMLElement>("[data-site-toast-message]");
  const submitButton = contactForm?.querySelector<HTMLButtonElement>("[type='submit']");
  const submitLabel = contactForm?.querySelector<HTMLElement>("[data-submit-label]");

  if (contactForm && toast && toastMessage && submitButton && submitLabel) {
    let toastTimer: number | undefined;

    const showToast = (message: string, tone: "success" | "error" = "success") => {
      window.clearTimeout(toastTimer);
      toastMessage.textContent = message;
      toast.dataset.tone = tone;
      toast.hidden = false;

      window.requestAnimationFrame(() => {
        toast.setAttribute("data-visible", "");
      });

      toastTimer = window.setTimeout(() => {
        toast.removeAttribute("data-visible");
        window.setTimeout(() => {
          toast.hidden = true;
        }, 280);
      }, 5200);
    };

    contactForm.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!contactForm.checkValidity()) {
        contactForm.reportValidity();
        return;
      }

      const formData = new FormData(contactForm);
      const encodedData = new URLSearchParams();

      formData.forEach((value, key) => {
        if (typeof value === "string") {
          encodedData.append(key, value);
        }
      });

      submitButton.disabled = true;
      submitLabel.textContent = "Sending";

      try {
        const response = await fetch(contactForm.action, {
          body: encodedData,
          headers: {
            "Content-Type": "application/x-www-form-urlencoded",
          },
          method: "POST",
        });

        if (!response.ok) {
          throw new Error("The form could not be submitted.");
        }

        contactForm.reset();
        showToast("Message sent. We'll follow up soon.");
      } catch {
        showToast("Something went wrong. Please try again.", "error");
      } finally {
        submitButton.disabled = false;
        submitLabel.textContent = "Continue";
      }
    });
  }
</script>
