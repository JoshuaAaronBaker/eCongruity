---
import { Menu, X } from "@lucide/astro";
import ButtonLink from "./ButtonLink.astro";

const headerNavItems = [
  { label: "What We Do", href: "/#work-heading" },
  { label: "About", href: "/about/" },
  { label: "Contact", href: "/contact/" },
];

const mobileNavItems = [
  { label: "Home", href: "/" },
  ...headerNavItems,
];

const normalizePath = (path: string) =>
  path.split("#")[0] !== "/" && path.split("#")[0].endsWith("/")
    ? path.split("#")[0].slice(0, -1)
    : path.split("#")[0];

const currentPath = normalizePath(Astro.url.pathname);

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  return normalizedHref === "/"
    ? currentPath === "/"
    : currentPath === normalizedHref;
};
---

<header class:list={[
  "site-header",
  currentPath === "/about" && "site-header--about",
  currentPath === "/contact" && "site-header--contact",
]}>
  <div class="site-container site-header__inner">
    <a class="brand-link" href="/" aria-label="eCongruity home">
      <img
        class="brand-link__logo"
        src="/images/brand/econgruity-logo-figma.png"
        alt=""
        width="1657"
        height="390"
        decoding="async"
      />
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {
        headerNavItems.map((item) => (
          <a
            href={item.href}
            class:list={["nav-link", isActive(item.href) && "nav-link--active"]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="desktop-cta">
      <ButtonLink href="/contact/" variant="secondary">Start a Project</ButtonLink>
    </div>

    <details class="mobile-nav">
      <summary aria-label="Open navigation">
        <Menu class="mobile-nav__icon mobile-nav__icon--menu" size={28} stroke-width={2.8} aria-hidden="true" />
        <X class="mobile-nav__icon mobile-nav__icon--close" size={27} stroke-width={2.6} aria-hidden="true" />
      </summary>
      <span class="mobile-nav__backdrop" hidden aria-hidden="true"></span>
      <nav class="mobile-nav__panel" hidden aria-label="Mobile navigation">
        {
          mobileNavItems.map((item) => (
            <a
              href={item.href}
              class:list={["mobile-nav__link", isActive(item.href) && "mobile-nav__link--active"]}
              aria-current={isActive(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
        <ButtonLink href="/contact/" variant="primary" class="mobile-nav__cta">
          Start a Project
        </ButtonLink>
      </nav>
    </details>
  </div>
</header>

<script>
  const siteHeader = document.querySelector<HTMLElement>(".site-header");

  if (siteHeader) {
    let lastScrollY = Math.max(window.scrollY, 0);
    let scrollFrame: number | undefined;

    const updateHeaderState = () => {
      const currentScrollY = Math.max(window.scrollY, 0);
      const isScrollingDown = currentScrollY > lastScrollY;
      const isScrollingUp = currentScrollY < lastScrollY;
      const mobileNavIsOpen = siteHeader.hasAttribute("data-mobile-nav-open");

      siteHeader.toggleAttribute("data-scrolled", currentScrollY > 12);

      if (mobileNavIsOpen || currentScrollY <= 12 || isScrollingUp) {
        siteHeader.removeAttribute("data-hidden");
      } else if (isScrollingDown && currentScrollY > siteHeader.offsetHeight) {
        siteHeader.setAttribute("data-hidden", "");
      }

      lastScrollY = currentScrollY;
      scrollFrame = undefined;
    };

    const requestHeaderUpdate = () => {
      if (scrollFrame !== undefined) {
        return;
      }

      scrollFrame = window.requestAnimationFrame(updateHeaderState);
    };

    updateHeaderState();
    window.addEventListener("scroll", requestHeaderUpdate, { passive: true });
  }

  const mobileNav = document.querySelector<HTMLDetailsElement>(".mobile-nav");
  const mobileNavSummary = mobileNav?.querySelector<HTMLElement>("summary");
  const mobileNavBackdrop = mobileNav?.querySelector<HTMLElement>(".mobile-nav__backdrop");
  const mobileNavPanel = mobileNav?.querySelector<HTMLElement>(".mobile-nav__panel");

  if (mobileNav && mobileNavSummary && mobileNavBackdrop && mobileNavPanel) {
    let closeTimer: number | undefined;
    document.body.append(mobileNavBackdrop, mobileNavPanel);

    const openMobileNav = () => {
      window.clearTimeout(closeTimer);
      mobileNav.open = true;
      mobileNav.removeAttribute("data-closing");
      mobileNavBackdrop.removeAttribute("data-closing");
      mobileNavPanel.removeAttribute("data-closing");
      mobileNavBackdrop.hidden = false;
      mobileNavPanel.hidden = false;
      siteHeader?.setAttribute("data-mobile-nav-open", "");
      siteHeader?.removeAttribute("data-hidden");

      window.requestAnimationFrame(() => {
        mobileNavBackdrop.setAttribute("data-open", "");
        mobileNavPanel.setAttribute("data-open", "");
      });
    };

    const closeMobileNav = (animate = true) => {
      window.clearTimeout(closeTimer);
      mobileNav.setAttribute("data-closing", "");
      mobileNavBackdrop.removeAttribute("data-open");
      mobileNavPanel.removeAttribute("data-open");
      mobileNavBackdrop.setAttribute("data-closing", "");
      mobileNavPanel.setAttribute("data-closing", "");

      const finishClose = () => {
        mobileNav.open = false;
        mobileNav.removeAttribute("data-closing");
        mobileNavBackdrop.removeAttribute("data-closing");
        mobileNavPanel.removeAttribute("data-closing");
        mobileNavBackdrop.hidden = true;
        mobileNavPanel.hidden = true;
        siteHeader?.removeAttribute("data-mobile-nav-open");
      };

      if (!animate) {
        finishClose();
        return;
      }

      closeTimer = window.setTimeout(finishClose, 320);
    };

    mobileNavSummary.addEventListener("click", (event) => {
      event.preventDefault();

      if (mobileNav.open) {
        closeMobileNav();
        return;
      }

      openMobileNav();
    });

    mobileNavPanel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        closeMobileNav(false);
      });
    });

    mobileNavBackdrop.addEventListener("click", () => closeMobileNav());

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && mobileNav.open) {
        closeMobileNav();
      }
    });
  }
</script>
