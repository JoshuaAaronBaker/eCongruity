---
import ContactForm from "../components/ContactForm.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../content/site";
---

<BaseLayout
  title="Contact"
  description="Start a conversation with eCongruity about the challenge you are trying to solve."
>
  <PageHero
    eyebrow="Contact"
    title="Start the conversation around the challenge."
    summary="The first step is a simple inquiry, not a quote request. Share what feels unclear, disconnected, stalled, or ready to grow."
  />

  <section class="section-band section-band--linen" aria-labelledby="contact-form-heading">
    <div class="site-container contact-grid">
      <div class="contact-intro">
        <p class="eyebrow">{site.contactCta}</p>
        <h2 id="contact-form-heading">Tell us what you are trying to solve.</h2>
        <p>
          Use the form to describe the challenge in plain business terms. eCongruity will help determine the right strategy, working group, implementation path, timeline, and cost through the planning conversation.
        </p>
        <div class="contact-note" aria-labelledby="contact-note-heading">
          <h3 id="contact-note-heading">What this form will not ask for</h3>
          <p>
            You do not need to estimate budget or timeline before the work is understood. The first conversation stays focused on the challenge and the operating context around it.
          </p>
        </div>
      </div>

      <ContactForm />
    </div>
  </section>
</BaseLayout>
