---
import ContactForm from "../components/ContactForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Start a conversation with eCongruity about the challenge you are trying to solve."
>
  <section class="contact-panel" aria-labelledby="contact-page-heading">
    <div class="site-container contact-grid contact-grid--feature">
      <div class="contact-intro">
        <p class="eyebrow">Get in Touch</p>
        <h1 id="contact-page-heading">
          Start with the challenge,
          <span>then build together.</span>
        </h1>
        <p>
          Whether you are working through unclear processes, disconnected systems, underused technology, or a stalled idea, the first step is a conversation about what you are trying to solve.
        </p>
        <dl class="contact-next-steps" aria-label="How the first conversation works">
          <div>
            <dt>First</dt>
            <dd>Describe the operating context in plain business terms.</dd>
          </div>
          <div>
            <dt>Then</dt>
            <dd>eCongruity helps shape the strategy, working group, implementation path, timeline, and cost.</dd>
          </div>
          <div>
            <dt>Not needed yet</dt>
            <dd>No budget or timeline estimate required before the challenge is understood.</dd>
          </div>
        </dl>
      </div>

      <div class="contact-form-wrap" aria-labelledby="contact-form-heading">
        <h2 id="contact-form-heading">Tell us what you are trying to solve.</h2>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
