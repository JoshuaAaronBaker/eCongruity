---
import ContactForm from "../components/ContactForm.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact"
  description="Start a conversation with eCongruity about the challenge you are trying to solve."
>
  <section class="contact-panel" aria-labelledby="contact-page-heading">
    <div class="site-container contact-grid contact-grid--feature">
      <div class="contact-intro">
        <p class="eyebrow">Get in Touch</p>
        <h1 id="contact-page-heading">
          <span class="contact-headline__line">Let's build</span>
          <span class="contact-headline__line">something</span>
          <span class="contact-headline__line contact-headline__line--accent"><em>together</em><small>.</small></span>
        </h1>
        <p>
          <span>Whether you're tackling a strategic challenge or launching something new — we want to hear about it.</span>
          <span>Tell us what you're working on.</span>
        </p>
        <span class="contact-divider" aria-hidden="true"></span>
        <dl class="contact-details">
          <div>
            <dt>Email</dt>
            <dd><a href="mailto:info@econgruity.com">info@econgruity.com</a></dd>
          </div>
          <div>
            <dt>Phone</dt>
            <dd><a href="tel:+14062230902">(406) 223-0902</a></dd>
          </div>
          <div>
            <dt>Location</dt>
            <dd>
              45 Business Park Road, Unit #C<br />
              Livingston, MT 59047
            </dd>
          </div>
        </dl>
      </div>

      <div class="contact-form-wrap" aria-labelledby="contact-form-heading">
        <h2 id="contact-form-heading">Tell us about your project</h2>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
