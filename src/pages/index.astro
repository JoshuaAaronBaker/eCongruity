---
import ButtonLink from "../components/ButtonLink.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  agileInnovationSteps,
  featuredCapabilities,
  homePaths,
  site,
  testimonials,
} from "../content/site";
---

<BaseLayout
  title={site.name}
  description="eCongruity is a Strategic Innovation Studio connecting people, process, and technology for real-time business."
>
  <section class="home-hero">
    <div class="site-container home-hero__grid">
      <div>
        <p class="eyebrow">{site.category}</p>
        <h1>Strategic Innovation Studio.</h1>
        <p class="home-hero__lead">
          {site.positioning}
        </p>
        <p class="home-hero__copy">
          eCongruity helps Organizational Leaders simplify Operational and Growth Complexity through strategy-to-implementation engagements that connect business judgment with hands-on implementation.
        </p>
        <p class="home-hero__metaphor">
          Nature Meets Innovation is our shorthand for intentional growth, systems thinking, and solutions that fit the environment they must live inside.
        </p>
        <div class="button-row">
          <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
          <ButtonLink href="/approach/" variant="secondary">Explore the Approach</ButtonLink>
        </div>
      </div>
      <div class="home-hero__panel" aria-label="How eCongruity connects work">
        <p class="home-hero__panel-label">People + Process + Technology</p>
        <div class="system-field" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <p>
          The work begins with the real operating context, then shapes the right strategy, working group, and implementation path.
        </p>
      </div>
    </div>
  </section>

  <section class="section-band section-band--linen" aria-labelledby="proof-heading">
    <div class="site-container">
      <div class="section-header">
        <p class="eyebrow">Client Stories</p>
        <h2 id="proof-heading">Proof stays close to the positioning.</h2>
        <p>
          Client stories show eCongruity helping leaders move from unclear complexity toward implemented, maintainable change.
        </p>
      </div>
      <div class="card-grid card-grid--three">
        {
          testimonials.map((testimonial) => (
            <article class="content-card">
              <p class="content-card__quote">"{testimonial.quote}"</p>
              <p class="content-card__meta">
                {testimonial.attribution} · {testimonial.status}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--stone" aria-labelledby="work-heading">
    <div class="site-container split-section">
      <div>
        <p class="eyebrow">What eCongruity Does</p>
        <h2 id="work-heading">Strategy and implementation belong in the same conversation.</h2>
      </div>
      <p>
        eCongruity brings together people, process, and technology to clarify the challenge, align the right Working Group, and carry the chosen path into a Tailored Solution.
      </p>
    </div>
  </section>

  <section class="section-band section-band--linen" aria-labelledby="capability-preview-heading">
    <div class="site-container">
      <div class="section-header section-header--with-action">
        <div>
          <p class="eyebrow">Selected Capabilities</p>
          <h2 id="capability-preview-heading">Examples that are shaped around the situation.</h2>
          <p>
            Capabilities are not preset choices. They are starting points for solving operational and growth complexity in the client's context.
          </p>
        </div>
        <ButtonLink href="/capabilities/" variant="secondary">View All Capabilities</ButtonLink>
      </div>
      <div class="card-grid card-grid--three">
        {
          featuredCapabilities.map((capability) => (
            <article class="content-card">
              <h3>{capability.title}</h3>
              <p>{capability.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--green" aria-labelledby="innovation-heading">
    <div class="site-container">
      <div class="section-header">
        <p class="eyebrow">Agile Innovation</p>
        <h2 id="innovation-heading">A repeatable way to move without forcing a rigid methodology.</h2>
        <p>
          The model keeps the work grounded in problem definition, collaboration, delivery, and learning so the solution can keep creating value after launch.
        </p>
      </div>
      <ol class="innovation-list">
        {
          agileInnovationSteps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section-band section-band--linen" aria-labelledby="path-heading">
    <div class="site-container">
      <div class="section-header">
        <p class="eyebrow">Explore the Studio</p>
        <h2 id="path-heading">Keep moving toward the right conversation.</h2>
      </div>
      <div class="home-path-grid">
        {
          homePaths.map((path) => (
            <a class="home-path-card" href={path.href}>
              <h3>{path.title}</h3>
              <p>{path.summary}</p>
              <span>{path.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--stone" aria-labelledby="cta-heading">
    <div class="site-container closing-cta">
      <div>
        <p class="eyebrow">Clear Path to Executable Growth</p>
        <h2 id="cta-heading">Start with the challenge. Shape the path together.</h2>
        <p>
          Share what feels unclear, disconnected, stalled, or ready to grow. eCongruity will help determine what strategy and implementation should look like from there.
        </p>
      </div>
      <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
    </div>
  </section>
</BaseLayout>
