---
import ButtonLink from "../components/ButtonLink.astro";
import ProofCarousel from "../components/ProofCarousel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  agileInnovationSteps,
  featuredCapabilities,
  homeDiagnostics,
  homePaths,
  site,
  testimonials,
} from "../content/site";
---

<BaseLayout
  title={site.name}
  description="eCongruity helps leaders turn operational and growth complexity into strategy-to-implementation work that can be carried into use."
>
  <section class="home-hero">
    <div class="site-container home-hero__grid">
      <div>
        <p class="hero-kicker">Founder-led strategy to implementation</p>
        <h1>Make the messy work executable.</h1>
        <p class="home-hero__lead">
          eCongruity helps leaders turn unclear processes, disconnected systems, and stalled ideas into a practical path forward.
        </p>
        <div class="button-row">
          <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
          <ButtonLink href="/approach/" variant="secondary">Explore the Approach</ButtonLink>
        </div>
      </div>
      <div class="home-hero__panel" aria-label="What eCongruity provides">
        <p class="home-hero__panel-label">What eCongruity provides</p>
        <ul class="hero-proof-list hero-proof-list--rotator">
          <li style="--i: 0">Strategy grounded in the real operating context.</li>
          <li style="--i: 1">Working-group alignment around the challenge.</li>
          <li style="--i: 2">Hands-on implementation when the path calls for it.</li>
        </ul>
      </div>
    </div>
  </section>

  <ProofCarousel testimonials={testimonials} />

  <section class="section-band section-band--stone" aria-labelledby="work-heading">
    <div class="site-container diagnosis-section">
      <div>
        <h2 id="work-heading">Start where complexity is showing up.</h2>
        <p>
          The most useful first conversation is not about a tool or a quote. It is about the places where momentum keeps getting stuck and what the organization needs to make the next move real.
        </p>
      </div>
      <div class="diagnostic-grid" role="list">
        {
          homeDiagnostics.map((item) => (
            <article class="diagnostic-card" role="listitem">
              <h3>{item.signal}</h3>
              <p>{item.firstMove}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--linen" aria-labelledby="capability-preview-heading">
    <div class="site-container">
      <div class="section-header section-header--with-action">
        <div>
          <p class="section-label">Selected capabilities</p>
          <h2 id="capability-preview-heading">The capability mix follows the situation.</h2>
          <p>
            These are not packages. They are examples of work that can become part of a strategy-to-implementation engagement once the operating context is clear.
          </p>
        </div>
        <ButtonLink href="/capabilities/" variant="secondary">View All Capabilities</ButtonLink>
      </div>
      <div class="card-grid card-grid--three">
        {
          featuredCapabilities.map((capability) => (
            <article class="content-card">
              <h3>{capability.title}</h3>
              <p>{capability.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--green" aria-labelledby="innovation-heading">
    <div class="site-container">
      <div class="section-header section-header--narrow">
        <p class="section-label section-label--dark">Agile Innovation</p>
        <h2 id="innovation-heading">A repeatable way to move without forcing a rigid methodology.</h2>
        <p>
          The model keeps the work grounded in problem definition, collaboration, delivery, and learning so the solution can keep creating value after launch.
        </p>
      </div>
      <ol class="innovation-list">
        {
          agileInnovationSteps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section-band section-band--linen" aria-labelledby="path-heading">
    <div class="site-container">
      <div class="section-header section-header--with-action">
        <div>
          <h2 id="path-heading">Choose the next question, not a preset service.</h2>
        </div>
        <p>
          Each path gives leaders a different way to evaluate fit: how the work moves, what eCongruity can bring, who guides it, and how to start.
        </p>
      </div>
      <div class="home-path-grid">
        {
          homePaths.map((path) => (
            <a class="home-path-card" href={path.href}>
              <h3>{path.title}</h3>
              <p>{path.summary}</p>
              <span>{path.label}</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--stone" aria-labelledby="cta-heading">
    <div class="site-container closing-cta">
      <div>
        <p class="section-label">Clear path to executable growth</p>
        <h2 id="cta-heading">Start with the challenge. Shape the path together.</h2>
        <p>
          Share what feels unclear, disconnected, stalled, or ready to grow. eCongruity will help determine what strategy and implementation should look like from there.
        </p>
      </div>
      <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
    </div>
  </section>
</BaseLayout>
