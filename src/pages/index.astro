---
import ButtonLink from "../components/ButtonLink.astro";
import ProofCarousel from "../components/ProofCarousel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  capabilities,
  site,
  testimonials,
} from "../content/site";

const titleCase = (value: string) =>
  value.replace(/\w\S*/g, (word) => word.charAt(0).toUpperCase() + word.slice(1));

const capabilitySlides = capabilities.map((capability) => ({
  ...capability,
  displayTitle: titleCase(capability.title),
}));

const whatCards = [
  {
    number: "01",
    title: "Big Picture",
    summary:
      "We help you step back, identify what's holding you back, and map exactly where you need to go.",
  },
  {
    number: "02",
    title: "Reframe",
    summary:
      "We turn the problem on its head — exploring fresh angles to unlock solutions tailored to your context.",
  },
  {
    number: "03",
    title: "Strategy",
    summary:
      "We focus your energy on the right paths, pinpointing strategic inroads that lead to innovative, lasting outcomes.",
  },
];

const processSteps = [
  {
    title: "Problem",
    summary:
      "Identify and define the challenge. To know the way forward, you need to understand what's holding you back.",
  },
  {
    title: "Ideation",
    summary:
      "Be creative and curious. We dig into solution ideas together, refining elegantly and inspiring next-step options.",
  },
  {
    title: "Collaboration",
    summary:
      "Put the right people in the room. We identify who needs to be at the table and keep everyone aligned.",
  },
  {
    title: "Solution",
    summary:
      "Implementation and efficient process. Whatever the chosen path, we help you put solutions into practice.",
  },
  {
    title: "Iteration",
    summary:
      "Lessons learned and next steps. We build in feedback loops for continuous improvement and adaptation.",
  },
  {
    title: "Growth",
    summary:
      "We scale what works. Building on proven foundations, we help you expand into new markets and opportunities.",
  },
];
---

<BaseLayout
  title={site.name}
  description="eCongruity helps leaders turn operational and growth complexity into strategy-to-implementation work that can be carried into use."
>
  <section class="home-hero">
    <img
      class="home-hero__mountain-image"
      src="/images/brand/hero-mountain-range.png"
      alt=""
      aria-hidden="true"
      decoding="async"
      fetchpriority="high"
    />
    <canvas
      class="home-hero__mountains"
      data-mountain-webgl
      aria-hidden="true"
    ></canvas>
    <div class="home-hero__stars" aria-hidden="true">
      {Array.from({ length: 14 }, (_, index) => <span class="home-hero__star" data-star={index + 1}></span>)}
    </div>
    <a class="home-hero__scroll-hint" href="#work-heading" aria-label="Scroll to What We Do">
      <span class="home-hero__scroll-line" aria-hidden="true"></span>
      <span class="home-hero__scroll-label" aria-hidden="true">Scroll</span>
    </a>
    <div class="site-container home-hero__grid">
      <div class="home-hero__content">
        <p class="hero-kicker">Strategic Innovation Studio</p>
        <h1>
          <span class="home-hero__title-line">Where <em>Nature</em></span>
          <span class="home-hero__title-line">Meets Innovation</span>
        </h1>
        <p class="home-hero__lead">
          <span class="copy-lines copy-lines--wide">
            <span>Connecting people, process, and technology for real-time</span>
            <span>business — sustainably, strategically, and with purpose.</span>
          </span>
          <span class="copy-lines copy-lines--mobile">
            <span>Connecting people, process, and technology</span>
            <span>for real-time business — sustainably,</span>
            <span>strategically, and with purpose.</span>
          </span>
        </p>
        <div class="button-row">
          <ButtonLink href="/approach/">Explore Our Approach</ButtonLink>
          <ButtonLink href="#proof-heading" variant="secondary">See Client Stories</ButtonLink>
        </div>
      </div>
    </div>
  </section>

  <section class="section-band section-band--linen what-section-band" aria-labelledby="work-heading">
    <div class="site-container what-section">
      <div class="what-section__copy">
        <p class="section-label">What We Do</p>
        <h2 id="work-heading">
          We simplify<br class="copy-break--wide" /> the<br class="copy-break--mobile" /> complex<br
            class="copy-break--wide"
          /> &amp; create a<br class="copy-break--mobile" /> clear<br class="copy-break--wide" /> path forward.
        </h2>
        <p class="what-section__body">
          eCongruity bridges the gap between big ideas and real-world execution. We blend strategic thinking with
          the right technologies to help organizations move faster, work smarter, and grow with intention.
        </p>
        <p class="what-section__cue">
          <span class="copy-lines copy-lines--wide">Tap a card for details</span>
          <span class="copy-lines copy-lines--mobile">Tap the cards</span>
        </p>
      </div>
      <div class="what-card-grid" role="list">
        {
          whatCards.map((card) => (
            <div class="what-card-item" role="listitem">
              <button
                class="what-card"
                type="button"
                data-flip-card
                aria-pressed="false"
                aria-label={`${card.number}. ${card.title}. ${card.summary}`}
              >
                <div class="what-card__inner">
                  <div class="what-card__face what-card__face--front" aria-hidden="true">
                    <span>{card.number}</span>
                    <h3>{card.title}</h3>
                  </div>
                  <div class="what-card__face what-card__face--back" aria-hidden="true">
                    <span>{card.number}</span>
                    <h3>{card.title}</h3>
                    <p>{card.summary}</p>
                  </div>
                </div>
              </button>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--green expertise-section" aria-labelledby="capability-preview-heading">
    <div class="site-container expertise-section__grid">
      <div class="expertise-intro">
        <p class="section-label section-label--dark">Our Expertise</p>
        <h2 id="capability-preview-heading">
          <span>The right tools.</span>
          <span>The right time.</span>
          <span>The right team.</span>
        </h2>
        <p class="expertise-sub">
          <span class="copy-lines copy-lines--wide">
            <span>We bring together best-in-class technologies and</span>
            <span>methodologies to take your solutions</span>
            <span>from concept to marketplace.</span>
          </span>
          <span class="copy-lines copy-lines--mobile">
            <span>We bring together best-in-class</span>
            <span>technologies and methodologies to take your</span>
            <span>solutions from concept to marketplace.</span>
          </span>
        </p>
      </div>
      <div class="expertise-focus" data-capability-carousel aria-label="Selected capabilities">
        <p>We specialize in</p>
        <div class="expertise-carousel" aria-live="polite">
          {
            capabilitySlides.map((capability, index) => (
              <article
                class="expertise-slide"
                data-capability-slide
                data-capability-active={index === 0 ? true : undefined}
                aria-hidden={index === 0 ? "false" : "true"}
              >
                <span>{capability.displayTitle}</span>
              </article>
            ))
          }
        </div>
        <div class="expertise-dots" aria-label="Select a capability">
          {
            capabilitySlides.map((capability, index) => (
              <button
                type="button"
                data-capability-dot
                aria-label={`Show ${capability.displayTitle}`}
                aria-current={index === 0 ? "true" : undefined}
              />
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section-band section-band--forest process-section" aria-labelledby="innovation-heading">
    <div class="site-container process-section__inner">
      <div class="section-header section-header--narrow process-section__header">
        <p class="section-label section-label--dark">Our Process</p>
        <h2 id="innovation-heading">
          <span>Agile Innovation —</span>
          <span>from challenge to</span>
          <span>change.</span>
        </h2>
        <p class="process-section__intro">
          <span class="copy-lines copy-lines--wide">
            <span>You have big ideas. We have a proven process to get you there</span>
            <span>quickly, collaboratively, and with built-in learning at every step.</span>
          </span>
          <span class="copy-lines copy-lines--mobile">
            <span>You have big ideas. We have a proven</span>
            <span>process to get you there quickly,</span>
            <span>collaboratively, and with built-in learning</span>
            <span>at every step.</span>
          </span>
        </p>
      </div>
      <ol class="innovation-list">
        {
          processSteps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <ProofCarousel testimonials={testimonials} />

  <section class="section-band section-band--green about-closing-section about-closing-section--about" aria-labelledby="cta-heading">
    <div class="about-closing__rings" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="site-container about-closing">
      <div class="about-closing__content">
        <p class="eyebrow">Work With Us</p>
        <h2 id="cta-heading">
          <span class="copy-lines copy-lines--wide">
            <span>Ready to build</span>
            <span>something that lasts?</span>
          </span>
          <span class="copy-lines copy-lines--mobile">
            <span>Ready to build</span>
            <span>something that</span>
            <span>lasts?</span>
          </span>
        </h2>
        <p class="about-closing__body">
          <span class="copy-lines copy-lines--wide">
            <span>Whether you're navigating a strategic challenge or launching</span>
            <span>something entirely new — we're ready to build with you.</span>
          </span>
          <span class="copy-lines copy-lines--mobile">
            <span>Whether you're navigating a strategic</span>
            <span>challenge or launching something entirely</span>
            <span>new — we're ready to build with you.</span>
          </span>
        </p>
      </div>
      <div class="button-row button-row--compact">
        <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
        <ButtonLink href="/" variant="secondary">Back to Home</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  import { initExclusiveFlipCards } from "../scripts/exclusiveFlipCards";
  import { initMountainParticles } from "../scripts/mountainParticles";

  initMountainParticles();
  initExclusiveFlipCards("[data-flip-card]");

  const capabilityCarousels = document.querySelectorAll<HTMLElement>("[data-capability-carousel]");

  capabilityCarousels.forEach((carousel) => {
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-capability-slide]"));
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-capability-dot]"));
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

    if (slides.length === 0 || dots.length === 0) {
      return;
    }

    let currentIndex = 0;
    let autoplay: number | undefined;

    const showSlide = (nextIndex: number) => {
      currentIndex = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, index) => {
        const isActive = index === currentIndex;
        slide.toggleAttribute("data-capability-active", isActive);
        slide.setAttribute("aria-hidden", String(!isActive));
      });

      dots.forEach((dot, index) => {
        if (index === currentIndex) {
          dot.setAttribute("aria-current", "true");
        } else {
          dot.removeAttribute("aria-current");
        }
      });
    };

    const restartAutoplay = () => {
      window.clearInterval(autoplay);

      if (prefersReducedMotion) {
        return;
      }

      autoplay = window.setInterval(() => {
        showSlide(currentIndex + 1);
      }, 3200);
    };

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        showSlide(index);
        restartAutoplay();
      });
    });

    carousel.addEventListener("pointerenter", () => window.clearInterval(autoplay));
    carousel.addEventListener("pointerleave", restartAutoplay);
    restartAutoplay();
  });
</script>
