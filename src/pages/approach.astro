---
import ButtonLink from "../components/ButtonLink.astro";
import HeroScrollButton from "../components/HeroScrollButton.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  agileInnovationSteps,
  challengeMapOutputs,
  approachComplexitySignals,
  engagementModel,
  site,
  workingGroupMembers,
} from "../content/site";
---

<BaseLayout
  title="Approach"
  description="The eCongruity approach moves from problem definition through hands-on implementation."
  footerVariant="about"
>
  <PageHero
    class="home-hero approach-hero"
    eyebrow="Approach"
    title="From complex challenge to implemented solution."
    summary="A Strategy-to-Implementation Engagement gives Organizational Leaders a guided way to make the challenge visible, align the right people, and carry a practical path into execution."
  >
    <span slot="title" class="home-hero__title-line">From challenge</span>
    <span slot="title" class="home-hero__title-line">to <em>clear change.</em></span>
    <span slot="summary">
      A Strategy-to-Implementation Engagement gives leaders a guided way to make the challenge visible, align the right people, and carry a practical path into execution.
    </span>
    <div class="approach-hero__orbit" aria-hidden="true"></div>
    <HeroScrollButton
      slot="after"
      href="#complexity-heading"
      label="Scroll to Operational and Growth Complexity"
    />
    <div class="button-row">
      <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
      <ButtonLink href="/capabilities/" variant="secondary">Explore Capabilities</ButtonLink>
    </div>
  </PageHero>

  <section class="section-band section-band--linen approach-complexity-section" aria-labelledby="complexity-heading">
    <div class="site-container approach-complexity">
      <div class="approach-complexity__intro">
        <p class="eyebrow">Operational and Growth Complexity</p>
        <h2 id="complexity-heading" class="theme-heading theme-heading--compact theme-heading--light">Make the messy parts specific enough to work on.</h2>
      </div>
      <div class="approach-complexity__copy">
        <p class="theme-lead theme-lead--light">
          eCongruity starts by naming the real conditions slowing progress: unclear processes, disconnected systems, underused technology, stalled ideas, and cross-functional misalignment.
        </p>
        <p class="theme-lead theme-lead--light">
          That operating context becomes the starting point for the Challenge Map: a shared picture of what is happening now, who needs to be involved, and what can move first.
        </p>
      </div>
    </div>
  </section>

  <section class="section-band section-band--forest approach-signals-section" aria-labelledby="signals-heading">
    <div class="site-container approach-signals">
      <div class="approach-signals__header">
        <p class="eyebrow">What It Can Look Like</p>
        <h2 id="signals-heading" class="theme-heading theme-heading--section theme-heading--dark">Recognizable signals inside complex work.</h2>
        <p class="theme-lead theme-lead--dark">
          These are the moments when the work needs a clearer operating picture before another platform, initiative, or process decision gets added.
        </p>
      </div>
      <div class="approach-signal-grid">
        {
          approachComplexitySignals.map((signal, index) => (
            <article>
              <span class="theme-number theme-number--dark">{String(index + 1).padStart(2, "0")}</span>
              <h3 class="theme-card-title theme-card-title--dark">{signal.title}</h3>
              <p class="theme-card-body theme-card-body--dark">{signal.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--linen approach-map-section" aria-labelledby="engagement-heading">
    <div class="site-container approach-map">
      <div class="approach-map__header">
        <p class="eyebrow">Strategy-to-Implementation Engagement</p>
        <h2 id="engagement-heading" class="theme-heading theme-heading--compact theme-heading--light">The Challenge Map keeps strategy and execution connected.</h2>
        <p class="theme-lead theme-lead--muted">
          eCongruity does not hand off an abstract plan and disappear. The Challenge Map becomes the shared reference for where to focus, who to involve, and which first executable slice can move the work through launch.
        </p>
      </div>
      <div class="approach-map__body">
        <ol class="approach-map-path">
          {
            engagementModel.map((item, index) => (
              <li>
                <span class="theme-number theme-number--light">{String(index + 1)}</span>
                <h3 class="theme-card-title theme-card-title--light">{item.title}</h3>
                <p class="theme-copy theme-copy--muted">{item.summary}</p>
              </li>
            ))
          }
        </ol>
        <aside class="approach-map__outputs" aria-label="Challenge Map outputs">
          <p>What the map makes visible</p>
          <div>
            {
              challengeMapOutputs.map((item) => (
                <article>
                  <h3 class="theme-card-title theme-card-title--light">{item.title}</h3>
                  <p class="theme-card-body theme-card-body--muted">{item.summary}</p>
                </article>
              ))
            }
          </div>
        </aside>
      </div>
    </div>
  </section>

  <section class="section-band section-band--forest process-section approach-process-section" aria-labelledby="process-heading">
    <div class="site-container process-section__inner approach-process">
      <div class="section-header section-header--narrow process-section__header approach-process__header">
        <p class="section-label section-label--dark">How the Map Moves</p>
        <h2 id="process-heading">
          <span>Agile Innovation gives</span>
          <span>the work a flexible</span>
          <span>cadence.</span>
        </h2>
        <p class="process-section__intro">
          The model is repeatable without becoming rigid. It keeps the Working Group moving through problem definition, reframing, collaboration, delivery, learning, and growth while the Challenge Map stays current.
        </p>
      </div>
      <ol class="innovation-list">
        {
          agileInnovationSteps.map((step, index) => (
            <li>
              <span class="theme-number theme-number--dark">{String(index + 1).padStart(2, "0")}</span>
              <h3 class="theme-card-title theme-card-title--dark">{step.title}</h3>
              <p class="theme-card-body theme-card-body--dark">{step.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section-band section-band--linen approach-working-section" aria-labelledby="working-group-heading">
    <div class="site-container approach-working">
      <div class="approach-working__header">
        <div>
          <p class="eyebrow">Working Group</p>
          <h2 id="working-group-heading" class="theme-heading theme-heading--section theme-heading--light">The right people around the challenge.</h2>
        </div>
        <p class="theme-lead theme-lead--muted">
          A Tailored Solution needs more than one viewpoint. eCongruity helps assemble the mix of decision authority, lived process knowledge, strategic guidance, implementation capacity, and outside expertise the map calls for.
        </p>
      </div>
      <div class="approach-working-grid">
        {
          workingGroupMembers.map((member) => (
            <article>
              <h3 class="theme-card-title theme-card-title--light">{member.title}</h3>
              <p class="theme-copy theme-copy--muted">{member.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--green about-closing-section about-closing-section--about approach-closing-section" aria-labelledby="outcome-heading">
    <div class="about-closing__rings" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="site-container about-closing">
      <div class="about-closing__content">
        <p class="eyebrow">Work With Us</p>
        <h2 id="outcome-heading">
          <span class="copy-lines copy-lines--wide">
            <span>Ready to build</span>
            <span>something that lasts?</span>
          </span>
          <span class="copy-lines copy-lines--mobile">
            <span>Ready to build</span>
            <span>something that</span>
            <span>lasts?</span>
          </span>
        </h2>
        <p class="about-closing__body">
          <span class="copy-lines copy-lines--wide">
            <span>Whether you're navigating a strategic challenge or launching</span>
            <span>something entirely new — we're ready to build with you.</span>
          </span>
          <span class="copy-lines copy-lines--mobile">
            <span>Whether you're navigating a strategic</span>
            <span>challenge or launching something entirely</span>
            <span>new — we're ready to build with you.</span>
          </span>
        </p>
      </div>
      <div class="button-row button-row--compact">
        <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
        <ButtonLink href="/capabilities/" variant="secondary">Explore Capabilities</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
