---
import ButtonLink from "../components/ButtonLink.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  agileInnovationSteps,
  approachComplexitySignals,
  engagementModel,
  site,
  workingGroupMembers,
} from "../content/site";
---

<BaseLayout
  title="Approach"
  description="The eCongruity approach moves from problem definition through hands-on implementation."
>
  <PageHero
    eyebrow="Approach"
    title="From complex challenge to implemented solution."
    summary="A Strategy-to-Implementation Engagement gives Organizational Leaders a guided way to clarify the challenge, shape the right path, and carry that path into hands-on execution."
  >
    <div class="button-row">
      <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
      <ButtonLink href="/capabilities/" variant="secondary">Explore Capabilities</ButtonLink>
    </div>
  </PageHero>

  <section class="section-band section-band--linen" aria-labelledby="complexity-heading">
    <div class="site-container split-section">
      <div>
        <p class="eyebrow">Operational and Growth Complexity</p>
        <h2 id="complexity-heading">Make the messy parts specific enough to work on.</h2>
      </div>
      <div>
        <p>
          eCongruity helps leaders name the real conditions slowing progress: unclear processes, disconnected systems, underused technology, stalled ideas, and cross-functional misalignment.
        </p>
        <p>
          The work begins there because durable business change depends on understanding the operating context before choosing the implementation path.
        </p>
      </div>
    </div>
  </section>

  <section class="section-band section-band--stone" aria-labelledby="signals-heading">
    <div class="site-container">
      <div class="section-header">
        <p class="eyebrow">What It Can Look Like</p>
        <h2 id="signals-heading">Recognizable signals inside complex work.</h2>
      </div>
      <div class="card-grid card-grid--four">
        {
          approachComplexitySignals.map((signal) => (
            <article class="content-card">
              <h3>{signal.title}</h3>
              <p>{signal.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--green" aria-labelledby="engagement-heading">
    <div class="site-container">
      <div class="section-header">
        <p class="eyebrow">Strategy-to-Implementation Engagement</p>
        <h2 id="engagement-heading">Strategy and execution stay connected.</h2>
        <p>
          eCongruity does not hand off an abstract plan and disappear. When the chosen path requires it, the engagement includes strategic hands-on implementation: building, configuring, coordinating, or leading the work through launch.
        </p>
      </div>
      <ol class="approach-path">
        {
          engagementModel.map((item, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item.title}</h3>
              <p>{item.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section-band section-band--linen" aria-labelledby="process-heading">
    <div class="site-container">
      <div class="section-header">
        <p class="eyebrow">Agile Innovation</p>
        <h2 id="process-heading">A flexible process for durable business change.</h2>
        <p>
          The model is repeatable without being rigid. It keeps the Working Group moving through problem definition, reframing, collaboration, delivery, learning, and growth.
        </p>
      </div>
      <ol class="innovation-list innovation-list--light">
        {
          agileInnovationSteps.map((step, index) => (
            <li>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.summary}</p>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <section class="section-band section-band--stone" aria-labelledby="working-group-heading">
    <div class="site-container">
      <div class="section-header">
        <p class="eyebrow">Working Group</p>
        <h2 id="working-group-heading">The right people around the challenge.</h2>
        <p>
          A Tailored Solution needs more than one viewpoint. eCongruity helps assemble the necessary mix of decision authority, lived process knowledge, strategic guidance, implementation capacity, and outside expertise when the work calls for it.
        </p>
      </div>
      <div class="working-group-grid">
        {
          workingGroupMembers.map((member) => (
            <article class="working-group-card">
              <h3>{member.title}</h3>
              <p>{member.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--linen" aria-labelledby="outcome-heading">
    <div class="site-container closing-cta">
      <div>
        <p class="eyebrow">Clear Path to Executable Growth</p>
        <h2 id="outcome-heading">Start with the challenge. Build toward change that lasts.</h2>
        <p>
          The first conversation is not a quote request. It is a way to understand what feels unclear, disconnected, stalled, or ready to grow so the right strategy and implementation path can emerge.
        </p>
      </div>
      <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
    </div>
  </section>
</BaseLayout>
