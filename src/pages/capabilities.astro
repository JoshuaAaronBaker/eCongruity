---
import ButtonLink from "../components/ButtonLink.astro";
import HeroScrollButton from "../components/HeroScrollButton.astro";
import PageHero from "../components/PageHero.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { capabilities, site } from "../content/site";

const capabilitySignals = [
  "A process depends on manual handoffs, duplicate entry, or knowledge held by only a few people.",
  "A digital tool, CMS, learning platform, or mobile experience needs to fit the way the organization actually works.",
  "An idea has strategic support but needs the right Working Group, delivery path, and implementation momentum.",
];

const tailoredPrinciples = [
  {
    title: "Start with the operating context",
    summary:
      "The work begins by clarifying the organization's needs, constraints, decision points, and people closest to the challenge.",
  },
  {
    title: "Shape the right mix",
    summary:
      "Capabilities can combine across workflow, systems, content, learning, mobile, process, and innovation work when the challenge calls for it.",
  },
  {
    title: "Carry the path into use",
    summary:
      "Strategy stays connected to Hands-On Implementation so the Tailored Solution can move toward durable business change.",
  },
];
---

<BaseLayout
  title="Capabilities"
  description="Examples of eCongruity capabilities that can be shaped into tailored solutions."
>
  <PageHero
    class="capabilities-hero"
    eyebrow="Capabilities"
    title="Examples of work shaped around your situation."
    summary="Capabilities are starting points. eCongruity combines strategy, people, process, and technology around the organization's needs, constraints, and situation."
  >
    <span slot="title">The right tools for the <em>right moment.</em></span>
    <span slot="summary">
      Capabilities are starting points. eCongruity combines strategy, people, process, and technology around the organization's needs, constraints, and situation.
    </span>
    <div class="capabilities-hero__orbit" aria-hidden="true"></div>
    <HeroScrollButton
      slot="after"
      href="#recognize-heading"
      label="Scroll to Where This Fits"
    />
    <div class="button-row">
      <ButtonLink href="/approach/" variant="secondary">See the Approach</ButtonLink>
      <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
    </div>
  </PageHero>

  <section class="section-band section-band--linen capability-fit-section" aria-labelledby="recognize-heading">
    <div class="site-container capability-fit">
      <div class="capability-fit__intro">
        <p class="eyebrow">Where This Fits</p>
        <h2 id="recognize-heading">Look for the places where momentum keeps getting stuck.</h2>
      </div>
      <div class="capability-signal-list" role="list">
        {
          capabilitySignals.map((signal, index) => (
            <p role="listitem"><span>{String(index + 1)}</span>{signal}</p>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--forest capability-index-section" aria-labelledby="capabilities-heading">
    <div class="site-container capability-index">
      <div class="capability-index__header">
        <p class="eyebrow">Possible Work</p>
        <h2 id="capabilities-heading">Equal-weight examples, not preset choices.</h2>
        <p>
          Each area represents a kind of work eCongruity can bring into a Strategy-to-Implementation Engagement when it helps create a Clear Path to Executable Growth.
        </p>
      </div>
      <div class="capability-index-grid">
        {
          capabilities.map((capability, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{capability.title}</h3>
              <p>{capability.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--linen capability-tailored-section" aria-labelledby="tailored-heading">
    <div class="site-container capability-tailored">
      <div class="capability-tailored__header">
        <p class="eyebrow">Tailored Solution</p>
        <h2 id="tailored-heading">The answer is designed around the organization, not selected from a shelf.</h2>
        <p>
          Operational and Growth Complexity rarely sits in one neat category. eCongruity helps leaders connect the relevant capability areas into a practical solution path that can be implemented and maintained.
        </p>
      </div>
      <div class="capability-tailored-grid">
        {
          tailoredPrinciples.map((principle, index) => (
            <article>
              <span>{String(index + 1)}</span>
              <h3>{principle.title}</h3>
              <p>{principle.summary}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section-band section-band--green about-closing-section" aria-labelledby="next-heading">
    <div class="site-container about-closing">
      <div>
        <p class="eyebrow">Next Step</p>
        <h2 id="next-heading">See how the work moves, then start with the challenge.</h2>
        <p>
          Explore the engagement model behind the work, or share what feels unclear, disconnected, stalled, or ready to grow.
        </p>
      </div>
      <div class="button-row">
        <ButtonLink href="/approach/" variant="secondary">Explore Approach</ButtonLink>
        <ButtonLink href="/contact/">{site.contactCta}</ButtonLink>
      </div>
    </div>
  </section>
</BaseLayout>
